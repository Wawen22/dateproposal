# Telegram notification config
# 1. Crea un bot scrivendo a @BotFather su Telegram -> comando /newbot -> copia il token
# 2. Il chat_id e' dove ricevi le notifiche (vedi istruzioni nel README/chat)
# Copia questo file in .env.local e riempi i valori (NON committare .env.local)

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
